<Window x:Class="ProjetHippodrome.IHMs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjetHippodrome"
        mc:Ignorable="d"
        Title="Application hippodrome" Height="450" Width="800">

    <Window.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FF080DE6" Offset="0.0" />
            <GradientStop Color="#E0E0E0" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <TextBlock Text="Météo hippodrome"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="20,20,0,0" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top"/>

        <Button x:Name="BAffichageMeteo" Content="Afficher les mesures météo" 
                Margin="100,80,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                Width="250" Height="45"
                Background="#007AFF" Foreground="White" FontWeight="Bold" Click="BAffichageMeteo_Click">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>

        <Button x:Name="BPenetrometrie" Content="Afficher les mesures de penetrometrie" 
                Margin="100,150,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                Width="250" Height="45"
                Background="#007AFF" Foreground="White" FontWeight="Bold" Click="BPenetrometrie_Click">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="480,80,0,0" Width="260">
            <TextBlock Text="Recherche par Date / Heure" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <DatePicker x:Name="DatePickerMeteo" Margin="0,0,0,10"/>

            <ComboBox x:Name="ComboHeure" Margin="0,0,0,10" SelectedIndex="0">
                <ComboBoxItem Content="Toute la journée (288 mesures)"/>
                <ComboBoxItem Content="00:00 (Moyenne)"/>
                <ComboBoxItem Content="01:00 (Moyenne)"/>
                <ComboBoxItem Content="02:00 (Moyenne)"/>
                <ComboBoxItem Content="03:00 (Moyenne)"/>
                <ComboBoxItem Content="04:00 (Moyenne)"/>
                <ComboBoxItem Content="05:00 (Moyenne)"/>
                <ComboBoxItem Content="06:00 (Moyenne)"/>
                <ComboBoxItem Content="07:00 (Moyenne)"/>
                <ComboBoxItem Content="08:00 (Moyenne)"/>
                <ComboBoxItem Content="09:00 (Moyenne)"/>
                <ComboBoxItem Content="10:00 (Moyenne)"/>
                <ComboBoxItem Content="11:00 (Moyenne)"/>
                <ComboBoxItem Content="12:00 (Moyenne)"/>
                <ComboBoxItem Content="13:00 (Moyenne)"/>
                <ComboBoxItem Content="14:00 (Moyenne)"/>
                <ComboBoxItem Content="15:00 (Moyenne)"/>
                <ComboBoxItem Content="16:00 (Moyenne)"/>
                <ComboBoxItem Content="17:00 (Moyenne)"/>
                <ComboBoxItem Content="18:00 (Moyenne)"/>
                <ComboBoxItem Content="19:00 (Moyenne)"/>
                <ComboBoxItem Content="20:00 (Moyenne)"/>
                <ComboBoxItem Content="21:00 (Moyenne)"/>
                <ComboBoxItem Content="22:00 (Moyenne)"/>
                <ComboBoxItem Content="23:00 (Moyenne)"/>
            </ComboBox>

            <Button x:Name="BtnRechercher" Content="🔎 Rechercher" Height="35" 
                    Background="#28A745" Foreground="White" FontWeight="Bold" 
                    Click="BtnRechercher_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
        <StackPanel Margin="404,213,50,81">
            <TextBlock Text="Recherche ciblée par Date" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="39*"/>
                    <ColumnDefinition Width="172*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Date : " VerticalAlignment="Center"/>
                <DatePicker x:Name="DpRecherche" Grid.Column="1" Margin="5,0,5,0" Grid.ColumnSpan="2"/>

                <TextBlock Text="Heure : " Grid.Column="3" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtHeureRecherche" Grid.Column="4" Text="12:00:00" Padding="2" Margin="5,0,0,0"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Champ : " VerticalAlignment="Center"/>
                <ComboBox x:Name="CboChampRecherche" Grid.Column="1" Margin="5,0" SelectedIndex="0">
                    <ComboBoxItem Content="temp_air_deg"/>
                    <ComboBoxItem Content="humidite_air_pct"/>
                    <ComboBoxItem Content="pluviometrie_mm"/>
                    <ComboBoxItem Content="vent_vitesse_kmh"/>
                    <ComboBoxItem Content="ensoleillement_wm2"/>
                </ComboBox>
            </Grid>

            <UniformGrid Columns="2" Height="40">
                <Button Content="Route: Date/Champ" 
                    Margin="2" 
                    Background="#34C759" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    Click="BtnDateChamp_Click"/>

                <Button Content="Route: Date/Heure/Champ" 
                    Margin="2" 
                    Background="#5856D6" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    Click="BtnDateHeureChamp_Click"/>
            </UniformGrid>

            <TextBlock x:Name="TxtResultatRoute" Text="Résultat : -" Margin="0,10,0,0" FontStyle="Italic" HorizontalAlignment="Center"/>
        </StackPanel>
        <Button x:Name="BCre" Content="Configurer une ou plusieurs zones" 
            Margin="100,217,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
            Width="250" Height="45"
            Background="#007AFF" Foreground="White" FontWeight="Bold" Click="BCreationZone_Click">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>