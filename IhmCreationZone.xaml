<Window x:Class="ProjetHippodrome.IhmCreationZone"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjetHippodrome" xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
        mc:Ignorable="d"
        Title="Ihm_creationzone" Height="450" Width="800">

    <Window.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FF080DE6" Offset="0.0" />
            <GradientStop Color="#E0E0E0" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="307*"/>
            <ColumnDefinition Width="93*"/>
        </Grid.ColumnDefinitions>
        <gmap:GMapControl x:Name="MyGMap" Loaded="MyGMap_Loaded" MaxZoom="20" Margin="0,0,214,0" MouseDown="MyGMap_MouseDown" MouseUp="MyGMap_MouseUp" Panel.ZIndex="1" />

        <Button
        Margin="590,237,18,0"
        Background="#007AFF" 
        Foreground="White" 
        Content= "Enregistrer"
        FontWeight="Bold" Height="35" VerticalAlignment="Top" Click="BEnregistrer_Click" Grid.ColumnSpan="2">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>

        <Button x:Name="BRetourMenu" Content="Retour au menu"
        Margin="590,347,18,0"
        Background="#007AFF" 
        Foreground="White" 
        FontWeight="Bold" Height="35" VerticalAlignment="Top" Click="BRetourMenu_Click" Grid.ColumnSpan="2">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>
        <Button Content="Supprimer"
                Background="#007AFF" 
                Foreground="White" 
                FontWeight="Bold" Height="35" VerticalAlignment="Top" Click="BSupprimer_Click" Grid.ColumnSpan="2" Margin="592,292,16,0">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
