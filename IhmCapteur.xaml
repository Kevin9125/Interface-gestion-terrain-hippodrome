<Window x:Class="ProjetHippodrome.IhmCapteur"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjetHippodrome"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="763" Width="1079">
    <Window.Resources>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#F2F2F7"/>
            <Setter Property="BorderBrush" Value="#D1D1D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="10"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007AFF"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>


        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

    </Window.Resources>
    <DockPanel>

        <Grid Margin="20" Height="724">
            <Grid.RowDefinitions>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="589*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Grid.Column="0" Background="#FFC8DFF7" Margin="36,10,32,-8" Grid.RowSpan="2">
                <StackPanel Margin="10,10,14,-16">
                    <TextBlock Text="Météo"
               FontSize="22"
               FontWeight="SemiBold"
               Margin="0,0,0,20"/>

                    <Grid Height="600" Width="240">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="106"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Humidité du sol" Grid.Row="2" Grid.Column="0" VerticalAlignment="Top" Height="15" Grid.ColumnSpan="2" Margin="10,13,76,0"/>
                        <TextBox x:Name="TxtHumiditeSol" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Height="35" Margin="5,0,5,0"/>
                        <TextBlock Text="%" Grid.Row="2" Grid.Column="2" VerticalAlignment="Top" Margin="4,18,4,0" Height="15"/>

                        <TextBlock Text="Pluviométrie 24h" Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" Height="15" Margin="8,18,76,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="TxtPluviometrie24h" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Height="35" Margin="5,0,5,0"/>
                        <TextBlock Text="mm" Grid.Row="3" Grid.Column="2" VerticalAlignment="Top" Margin="4,19,4,0" Height="15"/>

                        <TextBlock Text="Pluviométrie 7j" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Height="15" Grid.ColumnSpan="2" Margin="5,0,81,0"/>
                        <TextBox x:Name="TxtPluviometrie7j" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Height="35" Margin="5,0,5,0"/>
                        <TextBlock Text="mm" Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Height="15"/>

                        <TextBlock Text="Arrosage ligne" Grid.Column="0" VerticalAlignment="Center" Height="15" Margin="10,0,76,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="TxtDateArrosageLigne" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Height="34" Margin="5,0,5,0"/>

                        <TextBlock Text="Arrosage virage" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Height="15" Grid.ColumnSpan="2" Margin="10,0,76,0"/>
                        <TextBox x:Name="TxtDateArrosageVirage" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Height="35" Margin="5,0,5,0"/>

                        <TextBlock Text="Evaporation (ETP)" Grid.Row="5" Grid.Column="0" VerticalAlignment="Top" Height="15" Margin="0,19,0,0"/>
                        <TextBox x:Name="TxtEvaporationETP" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Height="45" Margin="5,0,5,0"/>
                        <TextBlock Text="mm" Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Height="15"/>

                        <TextBlock Text="Hygrométrie air" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Height="15"/>
                        <TextBox x:Name="TxtHygrometrieAir" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" Height="35" Margin="5,0,5,0"/>
                        <TextBlock Text="%" Grid.Row="6" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Height="15"/>

                        <TextBlock Text="Température de l'air" Grid.Row="7" Grid.Column="0" VerticalAlignment="Top" Height="15" Margin="0,10,0,0"/>
                        <TextBox x:Name="TxtTemperatureAir" Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" Height="35" Margin="5,0,5,0"/>
                        <TextBlock Text="°C" Grid.Row="7" Grid.Column="2" VerticalAlignment="Top" Margin="8,13,0,0" Height="15"/>

                        <TextBlock Text="Température du sol" Grid.Row="8" Grid.Column="0" VerticalAlignment="Top" Height="15" Margin="0,19,0,0"/>
                        <TextBox x:Name="TxtTemperatureSol" Grid.Row="8" Grid.Column="1" VerticalAlignment="Top" Height="35" Margin="5,9,5,0"/>
                        <TextBlock Text="°C" Grid.Row="8" Grid.Column="2" VerticalAlignment="Top" Margin="8,19,0,0" Height="15"/>

                        <TextBlock Text="Vitesse du vent" Grid.Row="9" Grid.Column="0" VerticalAlignment="Top" Height="15" Margin="0,19,0,0"/>
                        <TextBox x:Name="TxtVitesseVent" Grid.Row="9" Grid.Column="1" VerticalAlignment="Top" Height="35" Margin="5,9,5,0"/>
                        <TextBlock Text="km/h" Grid.Row="9" Grid.Column="2" VerticalAlignment="Top" Margin="8,19,0,0" Height="15" FontSize="11"/>

                        <TextBlock Text="Ensoleillement" Grid.Row="10" Grid.Column="0" VerticalAlignment="Top" Height="15" Margin="0,19,0,0"/>
                        <TextBox x:Name="TxtEnsoleillement" Grid.Row="10" Grid.Column="1" VerticalAlignment="Top" Height="35" Margin="5,9,5,0"/>
                        <TextBlock Text="W/m²" Grid.Row="10" Grid.Column="2" VerticalAlignment="Top" Margin="8,19,0,0" Height="15" FontSize="11"/>

                        <TextBlock Text="Historique" Grid.Row="11" Grid.Column="0" VerticalAlignment="Center" Height="15"/>
                        <ComboBox x:Name="CboMesures" 
                                  Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2" 
                                  Height="30" Margin="5,5,5,5"
                                  ItemsSource="{Binding ListeMesures}"
                                  SelectionChanged="CboMesures_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Content="Actualiser les données"
                                Margin="22,10,18,0"
                                Background="#007AFF" 
                                Foreground="White" 
                                FontWeight="Bold" Grid.ColumnSpan="3" Height="35" VerticalAlignment="Top" Grid.Row="12" Click="Button_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,47,-10" Grid.RowSpan="2">
                <TextBlock x:Name="TxtDate" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <TextBlock x:Name="TxtHeure" FontWeight="SemiBold"/>
            </StackPanel>
            <Border Style="{StaticResource Card}" Grid.Column="1" Background="#FFC8DFF7" Margin="10,10,36,10" Grid.RowSpan="2">
                <Grid>
                    <Grid Width="120" Height="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0">
                        <Ellipse Stroke="#D1D1D6" StrokeThickness="2"/>

                        <TextBlock Text="N" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0" FontWeight="Bold"/>
                        <TextBlock Text="S" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2" FontWeight="Bold"/>
                        <TextBlock Text="E" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,2,0" FontWeight="Bold"/>
                        <TextBlock Text="O" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0" FontWeight="Bold"/>

                        <Line X1="60" Y1="60" X2="60" Y2="15" 
          Stroke="#FF3B30" StrokeThickness="3" StrokeStartLineCap="Round">
                            <Line.RenderTransform>
                                <RotateTransform x:Name="RotationVent" Angle="90" CenterX="60" CenterY="60"/>
                            </Line.RenderTransform>
                        </Line>

                        <Ellipse Width="8" Height="8" Fill="#007AFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20">
                        <Grid Height="200" Margin="0,0,5,0"/>
                    </StackPanel>

                    <Grid Margin="101,20,130,76">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="53.84"/>
                            <RowDefinition Height="2"/>
                            <RowDefinition Height="197"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <lvc:CartesianChart x:Name="PluieChart"
                    Margin="18,0,35,0"
                    Height="180"
                    VerticalAlignment="Center" Grid.Row="2">

                            <lvc:CartesianChart.Series>
                                <lvc:ColumnSeries Title="Pluviométrie"
                          Values="{Binding PluieValues}"
                          DataLabels="True"/>
                            </lvc:CartesianChart.Series>

                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding Labels}" Foreground="Black" />
                            </lvc:CartesianChart.AxisX>

                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="mm" Foreground="Black" />
                            </lvc:CartesianChart.AxisY>

                        </lvc:CartesianChart>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-2,0,0" Height="46" Width="200">
                            <TextBlock Text="RISQUE DE SÉCHAGE (ETP)" FontWeight="Bold" FontSize="12" Foreground="#444" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Grid Width="200" Height="25">
                                <Border Background="#D1D1D6" CornerRadius="12" />

                                <Border x:Name="EtpRiskBar" HorizontalAlignment="Left" Width="0" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF22B14C" Offset="0"/>
                                            <GradientStop Color="#FFFFF200" Offset="0.5"/>
                                            <GradientStop Color="#FFED1C24" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <TextBlock x:Name="TxtEtpStatus" Text="Normal" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Color="Black"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            <Button x:Name="BRetourMenu" Content="Retour au menu"
                Margin="359,608,71,0"
                Background="#007AFF" 
                Foreground="White" 
                FontWeight="Bold" Height="35" VerticalAlignment="Top" Click="BRetourMenu_Click" Grid.Column="1" Grid.Row="1">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </DockPanel>
    <Window.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FF080DE6" Offset="0.0" />
            <GradientStop Color="#E0E0E0" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>
</Window>
